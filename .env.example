# ============================================================
# WaadCare System — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in values before running
# NEVER commit the real .env file to version control
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_PASSWORD=waad_local_db_password

# ── Spring Profile: use "dev" for local Docker, switch to "prod" later ─
SPRING_PROFILES_ACTIVE=dev

# ── Compose local DB wiring (override only if needed) ─────────
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/tba_waad_system
SPRING_DATASOURCE_USERNAME=postgres

# ── JWT Secret (min 64 characters, random) ────────────────────
JWT_SECRET=waad_local_jwt_secret_32_chars_minimum_value_2026

# ── Local bootstrap admin account ─────────────────────────────
ADMIN_DEFAULT_PASSWORD=Admin@123

# ── Frontend/API URL for local Docker ─────────────────────────
APP_FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
VITE_API_URL=/api/v1

# ── Nginx config selection: local Docker uses plain HTTP ─────
NGINX_CONFIG=nginx.local.conf

# ── Email (SMTP) ──────────────────────────────────────────────
EMAIL_ENABLED=true
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USERNAME=support@alwahacare.com
EMAIL_PASSWORD=CHANGE_ME_EMAIL_PASSWORD
EMAIL_FROM=support@alwahacare.com
EMAIL_FROM_NAME=شركة وعد لإدارة النفقات الطبية

# ── Security tuning (optional, defaults shown) ────────────────
REQUIRE_EMAIL_VERIFICATION=false
ACCOUNT_LOCKOUT_DURATION_MINUTES=30
MAX_FAILED_LOGIN_ATTEMPTS=5
PASSWORD_RESET_TOKEN_VALIDITY_HOURS=1
EMAIL_VERIFICATION_TOKEN_VALIDITY_HOURS=24

# ── File uploads ──────────────────────────────────────────────
SPRING_MULTIPART_MAX_FILE_SIZE=60MB
SPRING_MULTIPART_MAX_REQUEST_SIZE=60MB
