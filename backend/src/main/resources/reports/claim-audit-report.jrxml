<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="claim_audit_report"
              pageWidth="595" pageHeight="842" columnWidth="555"
              leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
              isTitleNewPage="true" >

    <property name="ireport.zoom" value="1.5"/>
    <property name="ireport.x" value="0"/>
    <property name="ireport.y" value="0"/>

    <!-- Styles -->
    <style name="BaseArabic" fontName="Amiri" fontSize="10" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
    <style name="HeaderCell" style="BaseArabic" isBold="true" mode="Opaque" backcolor="#F2F2F2"/>
    <style name="GroupHeader" style="BaseArabic" isBold="true" mode="Opaque" backcolor="#E0E0E0"/>
    <style name="SummaryBox" style="BaseArabic" mode="Opaque" backcolor="#FAFAFA"/>

    <!-- Parameters -->
    <parameter name="COMPANY_NAME" class="java.lang.String"/>
    <parameter name="COMPANY_LOGO" class="java.io.InputStream"/>
    <parameter name="REPORT_DATE" class="java.lang.String"/>
    <parameter name="REPORT_NUMBER" class="java.lang.String"/>
    <parameter name="PROVIDER_NAME" class="java.lang.String"/>
    
    <!-- Totals for Cover Page -->
    <parameter name="TOTAL_GROSS" class="java.math.BigDecimal"/>
    <parameter name="TOTAL_REJECTED" class="java.math.BigDecimal"/>
    <parameter name="TOTAL_NET" class="java.math.BigDecimal"/>
    <parameter name="CLAIM_COUNT" class="java.lang.Integer"/>

    <!-- Customizable Text -->
    <parameter name="INTRO_TEXT" class="java.lang.String"/>
    <parameter name="FOOTER_NOTE" class="java.lang.String"/>
    <parameter name="SIG_RIGHT_TOP" class="java.lang.String"/>
    <parameter name="SIG_RIGHT_BOTTOM" class="java.lang.String"/>
    <parameter name="SIG_LEFT_TOP" class="java.lang.String"/>
    <parameter name="SIG_LEFT_BOTTOM" class="java.lang.String"/>
    <parameter name="PRIMARY_COLOR" class="java.lang.String"/>

    <!-- Fields -->
    <field name="claimId" class="java.lang.Long"/>
    <field name="claimNo" class="java.lang.String"/>
    <field name="originNo" class="java.lang.String"/>
    <field name="insuranceNumber" class="java.lang.String"/>
    <field name="patientName" class="java.lang.String"/>
    <field name="complaint" class="java.lang.String"/>
    <field name="diagnosis" class="java.lang.String"/>
    <field name="serviceDate" class="java.util.Date"/>
    <field name="medicalService" class="java.lang.String"/>
    <field name="grossAmount" class="java.math.BigDecimal"/>
    <field name="netAmount" class="java.math.BigDecimal"/>
    <field name="rejectedAmount" class="java.math.BigDecimal"/>
    <field name="rejectionReason" class="java.lang.String"/>
    <field name="lineNo" class="java.lang.Integer"/>

    <!-- Variables -->
    <variable name="GROUP_GROSS" class="java.math.BigDecimal" resetType="Group" resetGroup="PatientGroup" calculation="Sum">
        <variableExpression><![CDATA[$F{grossAmount}]]></variableExpression>
    </variable>
    <variable name="GROUP_NET" class="java.math.BigDecimal" resetType="Group" resetGroup="PatientGroup" calculation="Sum">
        <variableExpression><![CDATA[$F{netAmount}]]></variableExpression>
    </variable>
    <variable name="GROUP_REJECTED" class="java.math.BigDecimal" resetType="Group" resetGroup="PatientGroup" calculation="Sum">
        <variableExpression><![CDATA[$F{rejectedAmount}]]></variableExpression>
    </variable>

    <!-- Group by Patient/Claim -->
    <group name="PatientGroup" isStartNewPage="true">
        <groupExpression><![CDATA[$F{claimId}]]></groupExpression>
        <groupHeader>
            <band height="140">
                <!-- Info Box (High Fidelity to IMG_20260313_144514.jpg) -->
                <frame>
                    <reportElement x="0" y="5" width="555" height="100" />
                    <box>
                        <pen lineWidth="0.75" lineColor="#999999"/>
                    </box>
                    
                    <!-- Row 1: No / Origin No -->
                    <staticText>
                        <reportElement style="HeaderCell" x="0" y="0" width="110" height="25" />
                        <box><rightPen lineWidth="0.5" lineColor="#AAAAAA"/></box>
                        <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                        <text><![CDATA[No:]]></text>
                    </staticText>
                    <textField>
                        <reportElement x="110" y="0" width="170" height="25" />
                        <box><rightPen lineWidth="0.5" lineColor="#AAAAAA"/></box>
                        <textElement textAlignment="Center" verticalAlignment="Middle"/>
                        <textFieldExpression><![CDATA[$F{claimNo}]]></textFieldExpression>
                    </textField>
                    
                    <staticText>
                        <reportElement style="HeaderCell" x="280" y="0" width="110" height="25" />
                        <box><rightPen lineWidth="0.5" lineColor="#AAAAAA"/></box>
                        <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                        <text><![CDATA[Origin No:]]></text>
                    </staticText>
                    <textField>
                        <reportElement x="390" y="0" width="165" height="25" />
                        <textElement textAlignment="Center" verticalAlignment="Middle"/>
                        <textFieldExpression><![CDATA[$F{originNo}]]></textFieldExpression>
                    </textField>

                    <!-- Row 2: Insurance / Patient -->
                    <staticText>
                        <reportElement style="HeaderCell" x="0" y="25" width="110" height="25" />
                        <box><topPen lineWidth="0.5" lineColor="#AAAAAA"/><rightPen lineWidth="0.5" lineColor="#AAAAAA"/></box>
                        <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                        <text><![CDATA[Insurance Number:]]></text>
                    </staticText>
                    <textField>
                        <reportElement x="110" y="25" width="170" height="25" />
                        <box><topPen lineWidth="0.5" lineColor="#AAAAAA"/><rightPen lineWidth="0.5" lineColor="#AAAAAA"/></box>
                        <textElement textAlignment="Center" verticalAlignment="Middle"/>
                        <textFieldExpression><![CDATA[$F{insuranceNumber}]]></textFieldExpression>
                    </textField>
                    
                    <staticText>
                        <reportElement style="HeaderCell" x="280" y="25" width="110" height="25" />
                        <box><topPen lineWidth="0.5" lineColor="#AAAAAA"/><rightPen lineWidth="0.5" lineColor="#AAAAAA"/></box>
                        <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                        <text><![CDATA[Patient Name:]]></text>
                    </staticText>
                    <textField>
                        <reportElement x="390" y="25" width="165" height="25" />
                        <box><topPen lineWidth="0.5" lineColor="#AAAAAA"/></box>
                        <textElement textAlignment="Right" verticalAlignment="Middle">
                            <font fontName="Amiri" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                            <paragraph rightIndent="5"/>
                        </textElement>
                        <textFieldExpression><![CDATA[$F{patientName}]]></textFieldExpression>
                    </textField>

                    <!-- Row 3: Complaint / Diagnosis -->
                    <staticText>
                        <reportElement style="HeaderCell" x="0" y="50" width="110" height="25" />
                        <box><topPen lineWidth="0.5" lineColor="#AAAAAA"/><rightPen lineWidth="0.5" lineColor="#AAAAAA"/></box>
                        <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                        <text><![CDATA[Complaint:]]></text>
                    </staticText>
                    <textField isBlankWhenNull="true">
                        <reportElement x="110" y="50" width="170" height="25" />
                        <box><topPen lineWidth="0.5" lineColor="#AAAAAA"/><rightPen lineWidth="0.5" lineColor="#AAAAAA"/></box>
                        <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Amiri"/><paragraph rightIndent="5"/></textElement>
                        <textFieldExpression><![CDATA[$F{complaint}]]></textFieldExpression>
                    </textField>
                    
                    <staticText>
                        <reportElement style="HeaderCell" x="280" y="50" width="110" height="25" />
                        <box><topPen lineWidth="0.5" lineColor="#AAAAAA"/><rightPen lineWidth="0.5" lineColor="#AAAAAA"/></box>
                        <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                        <text><![CDATA[Diagnosis:]]></text>
                    </staticText>
                    <textField isStretchWithOverflow="true" isBlankWhenNull="true">
                        <reportElement x="390" y="50" width="165" height="50" />
                        <box><topPen lineWidth="0.5" lineColor="#AAAAAA"/></box>
                        <textElement textAlignment="Right" verticalAlignment="Top">
                            <font fontName="Amiri" size="9"/>
                            <paragraph rightIndent="5"/>
                        </textElement>
                        <textFieldExpression><![CDATA[$F{diagnosis}]]></textFieldExpression>
                    </textField>
                </frame>

                <!-- Table Headers -->
                <frame>
                    <reportElement x="0" y="110" width="555" height="30" />
                    <staticText>
                        <reportElement style="HeaderCell" x="0" y="0" width="220" height="30" />
                        <box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box>
                        <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                        <text><![CDATA[Medical Service]]></text>
                    </staticText>
                    <staticText>
                        <reportElement style="HeaderCell" x="220" y="0" width="60" height="30" />
                        <box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box>
                        <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                        <text><![CDATA[Date]]></text>
                    </staticText>
                    <staticText>
                        <reportElement style="HeaderCell" x="280" y="0" width="65" height="30" />
                        <box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box>
                        <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                        <text><![CDATA[Gross]]></text>
                    </staticText>
                    <staticText>
                        <reportElement style="HeaderCell" x="345" y="0" width="65" height="30" />
                        <box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box>
                        <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                        <text><![CDATA[Net]]></text>
                    </staticText>
                    <staticText>
                        <reportElement style="HeaderCell" x="410" y="0" width="65" height="30" />
                        <box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box>
                        <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                        <text><![CDATA[Rejected]]></text>
                    </staticText>
                    <staticText>
                        <reportElement style="HeaderCell" x="475" y="0" width="80" height="30" />
                        <box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box>
                        <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                        <text><![CDATA[Rejection Reason]]></text>
                    </staticText>
                </frame>
            </band>
        </groupHeader>
        <groupFooter>
            <band height="30">
                <!-- Group Subtotal -->
                <frame>
                    <reportElement x="0" y="0" width="555" height="25" />
                    <box><topPen lineWidth="1.0" lineColor="#333333"/></box>
                    
                    <staticText>
                        <reportElement style="HeaderCell" x="0" y="0" width="280" height="25" backcolor="#F9F9F9"/>
                        <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="11"/></textElement>
                        <text><![CDATA[SUBTOTAL]]></text>
                    </staticText>
                    
                    <textField pattern="#,##0.000">
                        <reportElement x="280" y="0" width="65" height="25" />
                        <box><pen lineWidth="0.25" lineColor="#CCCCCC"/></box>
                        <textElement textAlignment="Right" verticalAlignment="Middle">
                            <font isBold="true" size="10"/>
                            <paragraph rightIndent="4"/>
                        </textElement>
                        <textFieldExpression><![CDATA[$V{GROUP_GROSS}]]></textFieldExpression>
                    </textField>
                    
                    <textField pattern="#,##0.000">
                        <reportElement x="345" y="0" width="65" height="25" forecolor="#006600" backcolor="#ECF9EE" mode="Opaque"/>
                        <box><pen lineWidth="0.25" lineColor="#CCCCCC"/></box>
                        <textElement textAlignment="Right" verticalAlignment="Middle">
                            <font isBold="true" size="10"/>
                            <paragraph rightIndent="4"/>
                        </textElement>
                        <textFieldExpression><![CDATA[$V{GROUP_NET}]]></textFieldExpression>
                    </textField>
                    
                    <textField pattern="#,##0.000">
                        <reportElement x="410" y="0" width="65" height="25" forecolor="#AA0000" backcolor="#FFF0F0" mode="Opaque"/>
                        <box><pen lineWidth="0.25" lineColor="#CCCCCC"/></box>
                        <textElement textAlignment="Right" verticalAlignment="Middle">
                            <font isBold="true" size="10"/>
                            <paragraph rightIndent="4"/>
                        </textElement>
                        <textFieldExpression><![CDATA[$V{GROUP_REJECTED}]]></textFieldExpression>
                    </textField>
                    
                    <textField>
                        <reportElement x="475" y="0" width="80" height="25" backcolor="#F9F9F9" mode="Opaque"/>
                        <textElement textAlignment="Center" verticalAlignment="Middle">
                            <font size="8" isItalic="true"/>
                        </textElement>
                        <textFieldExpression><![CDATA["د.ل"]]></textFieldExpression>
                    </textField>
                </frame>
            </band>
        </groupFooter>
    </group>

    <!-- Page 1: Cover Letter (Design Match to report11.jpg) -->
    <title>
        <band height="650" splitType="Stretch">
            <!-- Header for Cover Letter -->
            <image scaleImage="RetainShape" hAlign="Center">
                <reportElement x="210" y="0" width="135" height="45" />
                <imageExpression><![CDATA[$P{COMPANY_LOGO}]]></imageExpression>
            </image>
            <textField>
                <reportElement x="0" y="48" width="555" height="20" />
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Amiri" size="14" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{COMPANY_NAME}]]></textFieldExpression>
            </textField>
            
            <textField>
                <reportElement x="430" y="10" width="125" height="15" />
                <textElement textAlignment="Right"><font fontName="Amiri" size="10"/></textElement>
                <textFieldExpression><![CDATA["التاريخ: " + $P{REPORT_DATE}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="10" width="150" height="15" />
                <textElement textAlignment="Left"><font fontName="Amiri" size="10"/></textElement>
                <textFieldExpression><![CDATA["رقم الدفعة: " + $P{REPORT_NUMBER}]]></textFieldExpression>
            </textField>

            <!-- Salutation -->
            <textField>
                <reportElement x="0" y="100" width="555" height="25" />
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Amiri" size="12" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["السادة / " + $P{PROVIDER_NAME} + " المحترمين"]]></textFieldExpression>
            </textField>

            <!-- Intro Text -->
            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="140" width="555" height="60" />
                <textElement textAlignment="Right" verticalAlignment="Top" markup="none">
                    <font fontName="Amiri" size="12"/>
                    <paragraph lineSpacing="1_1_2"/>
                </textElement>
                <textFieldExpression><![CDATA[($P{INTRO_TEXT} != null && !$P{INTRO_TEXT}.isEmpty()) ? $P{INTRO_TEXT} : 
"نحيطكم علماً بأننا قد انتهينا من مراجعة المطالبات المالية المقدمة من طرفكم والمشار إليها في الدفعة رقم (" + $P{REPORT_NUMBER} + ")، وقد تمت المراجعة الفنية والمالية وفق المعايير المعتمدة، وكانت النتائج كالتالي:"]]></textFieldExpression>
            </textField>

            <!-- Results Summary Box -->
            <frame>
                <reportElement style="SummaryBox" x="100" y="220" width="355" height="110" />
                <box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box>
                
                <staticText>
                    <reportElement x="200" y="10" width="145" height="25" />
                    <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Amiri" size="11"/></textElement>
                    <text><![CDATA[• إجمالي القيمة المقدمة:]]></text>
                </staticText>
                <textField pattern="#,##0.000">
                    <reportElement x="10" y="10" width="180" height="25" />
                    <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Amiri" size="11" isBold="true"/></textElement>
                    <textFieldExpression><![CDATA[$P{TOTAL_GROSS} + " د.ل"]]></textFieldExpression>
                </textField>

                <staticText>
                    <reportElement x="200" y="40" width="145" height="25" />
                    <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Amiri" size="11"/></textElement>
                    <text><![CDATA[• إجمالي القيمة المرفوضة:]]></text>
                </staticText>
                <textField pattern="#,##0.000">
                    <reportElement x="10" y="40" width="180" height="25" forecolor="#AA0000" />
                    <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Amiri" size="11" isBold="true"/></textElement>
                    <textFieldExpression><![CDATA[$P{TOTAL_REJECTED} + " د.ل"]]></textFieldExpression>
                </textField>

                <staticText>
                    <reportElement x="200" y="70" width="145" height="25" />
                    <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Amiri" size="11"/></textElement>
                    <text><![CDATA[• صافي القيمة المستحقة:]]></text>
                </staticText>
                <textField pattern="#,##0.000">
                    <reportElement x="10" y="70" width="180" height="25" forecolor="#006600" />
                    <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Amiri" size="11" isBold="true"/></textElement>
                    <textFieldExpression><![CDATA[$P{TOTAL_NET} + " د.ل"]]></textFieldExpression>
                </textField>
            </frame>

            <!-- Closing Text -->
            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="350" width="555" height="40" />
                <textElement textAlignment="Right" verticalAlignment="Top">
                    <font fontName="Amiri" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA[($P{FOOTER_NOTE} != null && !$P{FOOTER_NOTE}.isEmpty()) ? $P{FOOTER_NOTE} : 
"يرجى التكرم بمراجعة التفاصيل والملاحظات المرفقة، وفي حال وجود أي اعتراض يرجى مراسلتنا في غضون أسبوعين من تاريخه."]]></textFieldExpression>
            </textField>

            <!-- Signatures -->
            <frame>
                <reportElement x="0" y="450" width="555" height="120" />
                
                <!-- Left Signature (Audit) -->
                <textField isBlankWhenNull="true">
                    <reportElement x="30" y="0" width="180" height="20" />
                    <textElement textAlignment="Center"><font fontName="Amiri" size="11" isBold="true"/></textElement>
                    <textFieldExpression><![CDATA[$P{SIG_LEFT_TOP} != null ? $P{SIG_LEFT_TOP} : "قسم المراجعة والتدقيق"]]></textFieldExpression>
                </textField>
                <line>
                    <reportElement x="30" y="60" width="180" height="1" />
                    <graphicElement><pen lineStyle="Dashed" lineColor="#999999"/></graphicElement>
                </line>
                <textField isBlankWhenNull="true">
                    <reportElement x="30" y="70" width="180" height="20" />
                    <textElement textAlignment="Center"><font fontName="Amiri" size="10"/></textElement>
                    <textFieldExpression><![CDATA[$P{SIG_LEFT_BOTTOM} != null ? $P{SIG_LEFT_BOTTOM} : ""]]></textFieldExpression>
                </textField>

                <!-- Right Signature (Management) -->
                <textField isBlankWhenNull="true">
                    <reportElement x="345" y="0" width="180" height="20" />
                    <textElement textAlignment="Center"><font fontName="Amiri" size="11" isBold="true"/></textElement>
                    <textFieldExpression><![CDATA[$P{SIG_RIGHT_TOP} != null ? $P{SIG_RIGHT_TOP} : "إدارة النفقات الطبية"]]></textFieldExpression>
                </textField>
                <line>
                    <reportElement x="345" y="60" width="180" height="1" />
                    <graphicElement><pen lineStyle="Dashed" lineColor="#999999"/></graphicElement>
                </line>
                <textField isBlankWhenNull="true">
                    <reportElement x="345" y="70" width="180" height="20" />
                    <textElement textAlignment="Center"><font fontName="Amiri" size="10"/></textElement>
                    <textFieldExpression><![CDATA[$P{SIG_RIGHT_BOTTOM} != null ? $P{SIG_RIGHT_BOTTOM} : "شركة وعد لإدارة النفقات"]]></textFieldExpression>
                </textField>
            </frame>

            <break><reportElement x="0" y="640" width="1" height="1" /></break>
        </band>
    </title>

    <!-- Detailed Pages Header (repeats after page 1) -->
    <pageHeader>
        <band height="65">
            <printWhenExpression><![CDATA[$V{PAGE_NUMBER} > 1]]></printWhenExpression>
            <image scaleImage="RetainShape" hAlign="Center">
                <reportElement x="240" y="0" width="75" height="30" />
                <imageExpression><![CDATA[$P{COMPANY_LOGO}]]></imageExpression>
            </image>
            <textField>
                <reportElement x="0" y="32" width="555" height="15" />
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="Amiri" size="11" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{COMPANY_NAME}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="430" y="5" width="125" height="12" />
                <textElement textAlignment="Right"><font fontName="Amiri" size="8"/></textElement>
                <textFieldExpression><![CDATA["التاريخ: " + $P{REPORT_DATE}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="430" y="17" width="125" height="12" />
                <textElement textAlignment="Right"><font fontName="Amiri" size="8"/></textElement>
                <textFieldExpression><![CDATA["الصفحة: " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="5" width="150" height="12" />
                <textElement textAlignment="Left"><font fontName="Amiri" size="8"/></textElement>
                <textFieldExpression><![CDATA["رقم الدفعة: " + $P{REPORT_NUMBER}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="55" width="555" height="1" forecolor="#CCCCCC"/>
            </line>
        </band>
    </pageHeader>

    <!-- Detailed Rows -->
    <detail>
        <band height="20" splitType="Stretch">
            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="0" width="220" height="20" />
                <box leftPadding="3" rightPadding="3"><pen lineWidth="0.25" lineColor="#DDDDDD"/></box>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Amiri" size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{medicalService}]]></textFieldExpression>
            </textField>
            <textField pattern="dd-MM-yyyy">
                <reportElement x="220" y="0" width="60" height="20" />
                <box><pen lineWidth="0.25" lineColor="#DDDDDD"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{serviceDate}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.000">
                <reportElement x="280" y="0" width="65" height="20" />
                <box rightPadding="3"><pen lineWidth="0.25" lineColor="#DDDDDD"/></box>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{grossAmount}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.000">
                <reportElement x="345" y="0" width="65" height="20" />
                <box rightPadding="3"><pen lineWidth="0.25" lineColor="#DDDDDD"/></box>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{netAmount}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.000">
                <reportElement x="410" y="0" width="65" height="20" />
                <box rightPadding="3"><pen lineWidth="0.25" lineColor="#DDDDDD"/></box>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{rejectedAmount}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true" isBlankWhenNull="true">
                <reportElement x="475" y="0" width="80" height="20" />
                <box leftPadding="3" rightPadding="3"><pen lineWidth="0.25" lineColor="#DDDDDD"/></box>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Amiri" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{rejectionReason}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <pageFooter>
        <band height="40">
            <line>
                <reportElement x="0" y="10" width="555" height="1" forecolor="#EEEEEE"/>
            </line>
            <textField>
                <reportElement x="0" y="15" width="555" height="15" forecolor="#666666" />
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Amiri" size="9" isItalic="true" />
                </textElement>
                <textFieldExpression><![CDATA[$P{COMPANY_NAME} + " - تقرير مراجعة المطالبات - " + $P{REPORT_DATE}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

</jasperReport>
